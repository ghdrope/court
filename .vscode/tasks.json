{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "debug-up",
      "type": "shell",
      "command": "docker compose -f docker-compose.debug up -d",
      "options": {
        "cwd": "${workspaceFolder}/hack/debug"
      },
      "problemMatcher": []
    },

    {
      "label": "debug-down",
      "type": "shell",
      "command": "docker compose -f docker-compose.debug down",
      "options": {
        "cwd": "${workspaceFolder}/hack/debug"
      },
      "problemMatcher": []
    }
  ]
}